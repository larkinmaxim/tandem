{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Tandem",
  "version": "0.1.0",
  "identifier": "com.tandem.app",
  "build": {
    "beforeDevCommand": {
      "script": "pnpm vite",
      "cwd": "..",
      "wait": false
    },
    "devUrl": "http://localhost:1521",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Tandem",
        "width": 800,
        "height": 600,
        "visible": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "dragDropEnabled": false,
        "trafficLightPosition": { "x": 12, "y": 22 }
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$HOME/.config/goose/avatars/**", "$HOME/.goose/avatars/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["../../../target/release/goose"],
    "macOS": {
      "entitlements": "entitlements.plist",
      "hardenedRuntime": true
    }
  }
}
